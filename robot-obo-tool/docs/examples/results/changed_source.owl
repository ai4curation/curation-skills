    <!-- http://purl.obolibrary.org/obo/UBERON_0002100 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0002100">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0011676"/>
