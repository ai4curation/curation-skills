    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001017"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000001"/>
        <owl:annotatedTarget>Part of the nervous system which includes the brain and spinal cord.[AAO]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-06-20</oboInOwl:date_retrieved>
        <oboInOwl:external_class>AAO:0000090</oboInOwl:external_class>
        <oboInOwl:ontology>AAO</oboInOwl:ontology>
